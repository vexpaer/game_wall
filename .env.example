# Never paste real credentials into chat or commit this file as .env.

# Steam (optional): Secret + repository variable.
STEAM_API_KEY=
STEAM_USER=
STEAM_LANGUAGE=schinese

# Xbox/OpenXBL (optional): Secret. A key identifies its own Xbox account.
OPENXBL_API_KEY=

# Epic/Legendary (optional): credentials are restored separately from encrypted state.
EPIC_SYNC_ENABLED=false
EPIC_DISPLAY_NAME=
LEGENDARY_CONFIG_PATH=

# Nintendo Switch manual or nxapi-derived import (optional).
SWITCH_IMPORT_FILE=
SWITCH_IMPORT_FORMAT=json
SWITCH_LOCALE=ja-JP
SWITCH_DISPLAY_NAME=
SWITCH_ACCOUNT_ID=
SWITCH_DEVICE=Nintendo Switch Lite

# Local CLI input only: temporarily load one provider's key, then clear it.
# Actions maps the separate EPIC_STATE_KEY/SWITCH_STATE_KEY secrets internally.
GAME_WALL_STATE_KEY=

# Optional paths.
GAME_WALL_ALIASES_FILE=data/game-aliases.json
GAME_WALL_DATA_FILE=data/generated/site-snapshot.json
