---
import Icon from "./Icon.astro";

interface Props {
  label: string;
  value: string | number;
  detail: string;
  icon: "clock" | "gamepad" | "spark" | "trophy";
  tone?: "cyan" | "lime" | "amber" | "violet";
}

const { label, value, detail, icon, tone = "cyan" } = Astro.props;
---

<article class:list={["metric-card", `metric-card--${tone}`]}>
  <div class="metric-card__top">
    <p>{label}</p>
    <span class="metric-card__icon" aria-hidden="true"><Icon name={icon} size={19} /></span>
  </div>
  <strong>{value}</strong>
  <small>{detail}</small>
</article>

<style>
  .metric-card {
    position: relative;
    min-width: 0;
    min-height: 150px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    overflow: hidden;
    border-radius: 22px;
    background:
      radial-gradient(circle at 100% 0, color-mix(in srgb, var(--metric-color) 12%, transparent), transparent 8rem),
      linear-gradient(145deg, rgba(255, 255, 255, 0.032), transparent 58%),
      var(--surface);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.18);
    transition: border-color 180ms ease, transform 180ms ease;
  }

  .metric-card::before {
    position: absolute;
    top: 0;
    right: 20px;
    left: 20px;
    height: 2px;
    content: "";
    background: linear-gradient(90deg, transparent, var(--metric-color), transparent);
    opacity: 0.72;
  }

  .metric-card:hover {
    border-color: color-mix(in srgb, var(--metric-color) 32%, transparent);
    transform: translateY(-2px);
  }

  .metric-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .metric-card p,
  .metric-card small {
    margin: 0;
    color: var(--muted);
  }

  .metric-card p {
    font-size: 0.73rem;
    font-weight: 650;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .metric-card__icon {
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border-radius: 9px;
    color: var(--metric-color);
    background: color-mix(in srgb, var(--metric-color) 10%, transparent);
  }

  .metric-card strong {
    margin-top: 15px;
    overflow: hidden;
    color: var(--text);
    font-size: clamp(1.35rem, 2.2vw, 2rem);
    font-variant-numeric: tabular-nums;
    line-height: 1.05;
    letter-spacing: -0.04em;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .metric-card small {
    margin-top: auto;
    padding-top: 8px;
    font-size: 0.73rem;
  }

  .metric-card--cyan {
    --metric-color: var(--cyan);
  }

  .metric-card--lime {
    --metric-color: var(--lime);
  }

  .metric-card--amber {
    --metric-color: var(--amber);
  }

  .metric-card--violet {
    --metric-color: var(--violet);
  }
</style>
