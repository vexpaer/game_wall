---
import Icon from "./Icon.astro";

interface Props {
  label: string;
  value: string | number;
  detail: string;
  icon: "clock" | "gamepad" | "spark" | "trophy";
  tone?: "cyan" | "lime" | "amber" | "violet";
}

const { label, value, detail, icon, tone = "cyan" } = Astro.props;
---

<article class:list={["metric-card", `metric-card--${tone}`]}>
  <div class="metric-card__top">
    <p>{label}</p>
    <span class="metric-card__icon" aria-hidden="true"><Icon name={icon} size={19} /></span>
  </div>
  <strong>{value}</strong>
  <small>{detail}</small>
</article>

<style>
  .metric-card {
    position: relative;
    min-width: 0;
    min-height: 150px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(229, 218, 255, 0.14);
    overflow: hidden;
    border-radius: 22px;
    background:
      radial-gradient(circle at 100% 0, color-mix(in srgb, var(--metric-color) 18%, transparent), transparent 9rem),
      linear-gradient(145deg, rgba(255, 255, 255, 0.045), transparent 58%),
      rgba(16, 9, 27, 0.94);
    box-shadow: 0 20px 52px rgba(0, 0, 0, 0.24), inset 0 1px rgba(255, 255, 255, 0.035);
    transition: border-color 180ms ease, box-shadow 180ms ease;
    will-change: transform;
  }

  .metric-card::before {
    position: absolute;
    top: 0;
    right: 20px;
    left: 20px;
    height: 2px;
    content: "";
    background: linear-gradient(90deg, transparent, var(--metric-color), transparent);
    opacity: 0.9;
    box-shadow: 0 0 15px color-mix(in srgb, var(--metric-color) 42%, transparent);
  }

  .metric-card::after {
    position: absolute;
    right: -44px;
    bottom: -56px;
    width: 118px;
    height: 118px;
    pointer-events: none;
    border: 1px solid color-mix(in srgb, var(--metric-color) 18%, transparent);
    border-radius: 50%;
    content: "";
    box-shadow: 0 0 0 16px color-mix(in srgb, var(--metric-color) 3%, transparent), 0 0 0 32px color-mix(in srgb, var(--metric-color) 2%, transparent);
  }

  .metric-card:hover {
    border-color: color-mix(in srgb, var(--metric-color) 48%, transparent);
    box-shadow: 0 28px 64px rgba(0, 0, 0, 0.34), 0 0 34px color-mix(in srgb, var(--metric-color) 8%, transparent);
  }

  .metric-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .metric-card p,
  .metric-card small {
    margin: 0;
    color: var(--muted);
  }

  .metric-card p {
    font-size: 0.73rem;
    font-weight: 650;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .metric-card__icon {
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border-radius: 9px;
    color: var(--metric-color);
    background: color-mix(in srgb, var(--metric-color) 10%, transparent);
    box-shadow: inset 0 0 18px color-mix(in srgb, var(--metric-color) 8%, transparent);
    transition: rotate 280ms ease, scale 280ms ease;
  }

  .metric-card:hover .metric-card__icon {
    rotate: 9deg;
    scale: 1.08;
  }

  .metric-card strong {
    margin-top: 15px;
    overflow: hidden;
    color: var(--text);
    font-size: clamp(1.35rem, 2.2vw, 2rem);
    font-variant-numeric: tabular-nums;
    line-height: 1.05;
    letter-spacing: -0.04em;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .metric-card small {
    margin-top: auto;
    padding-top: 8px;
    font-size: 0.73rem;
  }

  .metric-card--cyan {
    --metric-color: var(--cyan);
  }

  .metric-card--lime {
    --metric-color: var(--lime);
  }

  .metric-card--amber {
    --metric-color: var(--amber);
  }

  .metric-card--violet {
    --metric-color: var(--violet);
  }
</style>
