---
import { gameSources, type SiteSnapshot, type SourceAccount } from "../types/library";
import { formatDate } from "../utils/format";
import { sourceLabels } from "../utils/library";
import Icon from "./Icon.astro";

interface Props {
  snapshot: SiteSnapshot;
}

const { snapshot } = Astro.props;
const accountBySource = new Map(snapshot.accounts.map((account) => [account.source, account]));
const accounts: SourceAccount[] = gameSources.map((source) => accountBySource.get(source) ?? { source, status: "not_configured" });
const statusLabels = {
  ready: "已连接",
  private: "资料未公开",
  empty: "已连接，无记录",
  not_configured: "未绑定",
  unavailable: "同步暂不可用",
  needs_rebind: "需要重新绑定"
} as const;
const hasAttention = accounts.some((account) => ["private", "unavailable", "needs_rebind"].includes(account.status));
const title = hasAttention ? "游戏库暂时没有可展示数据" : "还没有可展示的游戏";
const description = hasAttention
  ? "至少一个平台需要检查公开权限、登录状态或同步任务。其他平台仍可独立绑定和更新。"
  : "绑定游戏平台并运行同步任务后，游戏会同时出现在合并视图和分平台视图中。";
---

<section class="status-page" aria-labelledby="status-title">
  <div class="status-panel">
    <span class="status-panel__icon" aria-hidden="true"><Icon name="gamepad" size={34} /></span>
    <p class="section-kicker">MULTI-PLATFORM LIBRARY STATUS</p>
    <h1 id="status-title">{title}</h1>
    <p class="status-panel__description">{description}</p>
    <div class="status-panel__accounts" aria-label="游戏平台同步状态">
      {accounts.map((account) => (
        <article class={`status-account status-account--${account.status}`}>
          <span>{sourceLabels[account.source]}</span>
          <strong>{statusLabels[account.status]}</strong>
          <small>{account.lastSyncedAt ? `上次同步 ${formatDate(account.lastSyncedAt, true)}` : "尚无成功同步记录"}</small>
        </article>
      ))}
    </div>
    <p class="status-panel__time">数据检查于 {formatDate(snapshot.generatedAt, true)}</p>
  </div>
</section>

<style>
  .status-page {
    min-height: 66vh;
    padding: 76px 0 24px;
    display: grid;
    place-items: center;
  }

  .status-panel {
    width: min(680px, 100%);
    padding: clamp(32px, 7vw, 64px);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    text-align: center;
    background:
      radial-gradient(circle at 50% 0, rgba(255, 138, 101, 0.14), transparent 17rem),
      var(--surface);
    box-shadow: var(--shadow);
  }

  .status-panel__icon {
    width: 70px;
    height: 70px;
    margin: 0 auto 24px;
    display: grid;
    place-items: center;
    border: 1px solid rgba(255, 138, 101, 0.32);
    border-radius: 20px;
    color: var(--cyan);
    background: rgba(255, 138, 101, 0.08);
  }

  .status-panel .section-kicker {
    justify-content: center;
  }

  .status-panel h1 {
    margin: 10px 0 0;
    font-size: clamp(1.8rem, 5vw, 3rem);
    line-height: 1.16;
    letter-spacing: -0.04em;
  }

  .status-panel__description {
    max-width: 500px;
    margin: 18px auto 0;
    color: var(--muted-strong);
  }

  .status-panel__actions {
    margin-top: 30px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
  }

  .status-panel__accounts {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 9px;
    text-align: left;
  }

  .status-account {
    min-width: 0;
    padding: 13px;
    display: grid;
    gap: 3px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: rgba(7, 4, 12, 0.45);
  }

  .status-account > span {
    color: var(--muted);
    font-size: 0.68rem;
  }

  .status-account > strong {
    font-size: 0.82rem;
  }

  .status-account > small {
    overflow-wrap: anywhere;
    color: var(--muted);
    font-size: 0.65rem;
  }

  .status-account--ready,
  .status-account--empty {
    border-color: rgba(202, 255, 72, 0.22);
  }

  .status-account--needs_rebind,
  .status-account--private,
  .status-account--unavailable {
    border-color: rgba(255, 167, 78, 0.32);
  }

  .button {
    min-height: 44px;
    padding: 9px 15px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: 1px solid var(--line-strong);
    border-radius: 10px;
    color: var(--muted-strong);
    font-size: 0.82rem;
    font-weight: 650;
  }

  .button--primary {
    border-color: transparent;
    color: #06121e;
    background: var(--cyan);
  }

  .status-panel__time {
    margin: 28px 0 0;
    color: var(--muted);
    font-size: 0.7rem;
  }

  @media (max-width: 500px) {
    .status-page {
      padding-top: 48px;
    }

    .status-panel__actions,
    .button {
      width: 100%;
    }

    .status-panel__accounts {
      grid-template-columns: 1fr;
    }
  }
</style>
