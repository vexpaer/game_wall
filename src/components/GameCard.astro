---
import type { SteamGame } from "../types/steam";
import { formatDate, formatDuration } from "../utils/format";
import AchievementBadge from "./AchievementBadge.astro";
import Icon from "./Icon.astro";

interface Props {
  game: SteamGame;
  href: string;
  eager?: boolean;
}

const { game, href, eager = false } = Astro.props;
const cover = game.store.headerImageUrl;
const genres = game.store.genres.slice(0, 2);
const searchable = [game.name, ...game.store.genres, ...game.store.developers].join(" ").toLocaleLowerCase("zh-CN");
const platforms = game.store.platforms.join(" ").toLocaleLowerCase("en-US");
const percentage = game.achievements.percentage;
const achievementCategory =
  game.achievements.status === "none"
    ? "none"
    : game.achievements.status === "unavailable"
      ? "unavailable"
      : percentage >= 100
        ? "perfect"
        : game.achievements.unlocked > 0
          ? "progress"
          : "untouched";
const lastPlayed = game.lastPlayedAt ? Date.parse(game.lastPlayedAt) || 0 : 0;
---

<article
  class="game-card"
  data-game-card
  data-search={searchable}
  data-genres={game.store.genres.join("|").toLocaleLowerCase("zh-CN")}
  data-platforms={platforms}
  data-achievement={achievementCategory}
  data-last-played={lastPlayed}
  data-playtime={game.playtime.foreverMinutes}
  data-completion={percentage}
  data-name={game.name.toLocaleLowerCase("zh-CN")}
>
  <a class="game-card__link" href={href} aria-label={`查看 ${game.name} 详情`}>
    <div class:list={["game-card__art", !cover && "game-card__art--fallback"]}>
      {cover ? (
        <img
          src={cover}
          alt=""
          width="460"
          height="215"
          loading={eager ? "eager" : "lazy"}
          decoding="async"
        />
      ) : game.iconUrl ? (
        <img class="game-card__icon" src={game.iconUrl} alt="" width="32" height="32" loading="lazy" decoding="async" />
      ) : (
        <span class="game-card__monogram" aria-hidden="true">{game.name.slice(0, 1).toLocaleUpperCase("zh-CN")}</span>
      )}
      <span class="game-card__appid">APP {game.appId}</span>
    </div>
    <div class="game-card__body">
      <div class="game-card__title-row">
        <div>
          <h3>{game.name}</h3>
          <p>{formatDuration(game.playtime.foreverMinutes)} · {formatDate(game.lastPlayedAt)}</p>
        </div>
        <span class="game-card__arrow" aria-hidden="true"><Icon name="arrow-up-right" size={18} /></span>
      </div>
      <div class="game-card__tags" aria-label="游戏类型">
        {genres.length > 0 ? genres.map((genre) => <span>{genre}</span>) : <span>游戏</span>}
        {game.playtime.recentMinutes > 0 && <span class="game-card__recent">近两周 {formatDuration(game.playtime.recentMinutes)}</span>}
      </div>
      <AchievementBadge achievements={game.achievements} compact />
    </div>
  </a>
</article>

<style>
  .game-card {
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.15);
    transition: border-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
  }

  .game-card:hover {
    border-color: var(--line-strong);
    transform: translateY(-3px);
    box-shadow: 0 23px 50px rgba(0, 0, 0, 0.24);
  }

  .game-card__link {
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .game-card__art {
    position: relative;
    aspect-ratio: 460 / 215;
    overflow: hidden;
    background:
      linear-gradient(120deg, rgba(86, 217, 237, 0.12), transparent 52%),
      var(--surface-raised);
  }

  .game-card__art::after {
    position: absolute;
    inset: 35% 0 0;
    content: "";
    background: linear-gradient(to bottom, transparent, rgba(4, 11, 21, 0.42));
  }

  .game-card__art > img:not(.game-card__icon) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
  }

  .game-card:hover .game-card__art > img:not(.game-card__icon) {
    transform: scale(1.025);
  }

  .game-card__art--fallback {
    display: grid;
    place-items: center;
    background:
      radial-gradient(circle at 70% 20%, rgba(155, 140, 255, 0.24), transparent 45%),
      linear-gradient(145deg, #173047, #0a1727 72%);
  }

  .game-card__art--fallback::before {
    position: absolute;
    width: 70%;
    height: 1px;
    content: "";
    background: linear-gradient(90deg, transparent, rgba(86, 217, 237, 0.4), transparent);
    transform: rotate(-24deg);
  }

  .game-card__icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    image-rendering: auto;
  }

  .game-card__monogram {
    color: rgba(255, 255, 255, 0.72);
    font-size: 3.2rem;
    font-weight: 800;
  }

  .game-card__appid {
    position: absolute;
    right: 12px;
    bottom: 10px;
    z-index: 1;
    padding: 3px 7px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 5px;
    color: rgba(255, 255, 255, 0.7);
    background: rgba(3, 9, 17, 0.64);
    backdrop-filter: blur(7px);
    font-size: 0.58rem;
    letter-spacing: 0.08em;
  }

  .game-card__body {
    flex: 1;
    padding: 17px;
    display: flex;
    flex-direction: column;
  }

  .game-card__title-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: start;
    gap: 14px;
  }

  .game-card h3 {
    margin: 0;
    overflow: hidden;
    font-size: 0.97rem;
    line-height: 1.35;
    letter-spacing: -0.015em;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .game-card__title-row p {
    margin: 4px 0 0;
    overflow: hidden;
    color: var(--muted);
    font-size: 0.68rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .game-card__arrow {
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 9px;
    color: var(--muted);
    transition: color 180ms ease, background 180ms ease;
  }

  .game-card:hover .game-card__arrow {
    color: var(--cyan);
    background: rgba(86, 217, 237, 0.08);
  }

  .game-card__tags {
    min-height: 27px;
    margin: 14px 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .game-card__tags span {
    padding: 3px 7px;
    border-radius: 5px;
    color: var(--muted-strong);
    background: rgba(145, 177, 199, 0.08);
    font-size: 0.62rem;
  }

  .game-card__tags .game-card__recent {
    color: var(--lime);
    background: rgba(167, 239, 96, 0.08);
  }

  .game-card[hidden] {
    display: none;
  }

  @media (max-width: 560px) {
    .game-card__body {
      padding: 15px;
    }
  }
</style>
